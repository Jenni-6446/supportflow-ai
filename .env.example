# Use "structured_llm" to enable LLM-assisted ticket analysis.
# Any other value uses the deterministic fallback provider.
AI_PROVIDER=structured_llm

# Configure one API-key variable. Never commit a real key.
OPENAI_API_KEY=your_api_key_here
LLM_API_KEY=your_api_key_here

LLM_MODEL=your_model_here

# Optional OpenAI-compatible chat-completions endpoint.
LLM_BASE_URL=https://api.example.com/v1/chat/completions
